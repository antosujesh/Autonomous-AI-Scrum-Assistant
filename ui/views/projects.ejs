<%- include('partials/head') %>

<!-- Actions Header -->
<div class="glass-card" style="margin-bottom: 2rem; display: flex; justify-content: space-between; align-items: center; padding: 1.25rem 1.5rem;">
    <div>
        <h2 style="margin:0; font-family: 'Outfit', sans-serif;">Projects Catalog</h2>
        <p style="margin:0; font-size: 0.85rem; color: var(--text-muted);">Organize your team's initiatives into trackable projects.</p>
    </div>
    <button class="btn btn-primary" onclick="openModal('addProjectModal')">
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"></line><line x1="5" y1="12" x2="19" y2="12"></line></svg>
        New Project
    </button>
</div>

<!-- Projects Grid -->
<div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(320px, 1fr)); gap: 1.5rem;">
    <% projects.forEach(project => { %>
        <div class="glass-card project-card" style="border-left: 4px solid <%= project.Color %>;">
            <div style="display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 1rem;">
                <h3 style="margin:0; font-family: 'Outfit', sans-serif; color: var(--text);"><%= project.Name %></h3>
                <span class="badge badge-<%= project.Status.toLowerCase().replace(' ', '') %>"><%= project.Status %></span>
            </div>
            
            <p style="font-size: 0.88rem; color: var(--text-muted); line-height: 1.5; margin-bottom: 1.5rem; min-height: 2.6rem;">
                <%= project.Description || 'No description provided.' %>
            </p>

            <div style="display: flex; gap: 0.75rem; border-top: 1px solid var(--border); pt: 1rem; margin-top: auto; padding-top: 1rem;">
                <button class="btn btn-ghost" style="flex: 1; font-size: 0.8rem;" onclick="editProject('<%= project.Id %>', '<%= project.Name.replace(/'/g, "\\'") %>', '<%= project.Description ? project.Description.replace(/'/g, "\\'") : '' %>', '<%= project.Color %>', '<%= project.Status %>')">Edit</button>
                <% if(project.Id != 1) { %>
                    <form action="/projects/delete/<%= project.Id %>" method="POST" style="margin:0;" onsubmit="return confirm('Deleting a project will move all its tasks to General. Proceed?')">
                        <button type="submit" class="btn btn-ghost" style="color: var(--danger); padding: 0 12px;">
                            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"></polyline><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path></svg>
                        </button>
                    </form>
                <% } %>
            </div>
        </div>
    <% }) %>
</div>

<!-- Add Modal -->
<div id="addProjectModal" class="modal">
    <div class="modal-content" style="max-width: 450px;">
        <div class="modal-header">
            <h2 class="modal-title">Launch New Project</h2>
            <button class="btn-close" onclick="closeModal('addProjectModal')">&times;</button>
        </div>
        <form action="/projects/add" method="POST">
            <div class="form-group">
                <label class="input-label">Project Name</label>
                <input type="text" name="name" class="input-field" placeholder="e.g., Q3 Marketing Push" required>
            </div>
            <div class="form-group">
                <label class="input-label">Description</label>
                <textarea name="description" class="input-field" style="min-height: 100px;"></textarea>
            </div>
            <div class="form-group">
                <label class="input-label">Brand Color</label>
                <input type="color" name="color" value="#4f46e5" style="width: 100%; height: 40px; border: 1px solid var(--border); border-radius: 8px; cursor: pointer;">
            </div>
            <div class="modal-footer" style="margin-top: 1.5rem;">
                <button type="button" class="btn btn-ghost" onclick="closeModal('addProjectModal')">Cancel</button>
                <button type="submit" class="btn btn-primary">Create Project</button>
            </div>
        </form>
    </div>
</div>

<!-- Edit Modal -->
<div id="editProjectModal" class="modal">
    <div class="modal-content" style="max-width: 450px;">
        <div class="modal-header">
            <h2 class="modal-title">Modify Project</h2>
            <button class="btn-close" onclick="closeModal('editProjectModal')">&times;</button>
        </div>
        <form action="/projects/update" method="POST">
            <input type="hidden" name="id" id="editProjectId">
            <div class="form-group">
                <label class="input-label">Project Name</label>
                <input type="text" name="name" id="editProjectName" class="input-field" required>
            </div>
            <div class="form-group">
                <label class="input-label">Description</label>
                <textarea name="description" id="editProjectDesc" class="input-field" style="min-height: 100px;"></textarea>
            </div>
            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem;">
                <div class="form-group">
                    <label class="input-label">Color</label>
                    <input type="color" name="color" id="editProjectColor" style="width: 100%; height: 40px; border: 1px solid var(--border); border-radius: 8px;">
                </div>
                <div class="form-group">
                    <label class="input-label">Status</label>
                    <select name="status" id="editProjectStatus" class="input-field">
                        <option value="Active">Active</option>
                        <option value="On Hold">On Hold</option>
                        <option value="Completed">Completed</option>
                        <option value="Cancelled">Cancelled</option>
                    </select>
                </div>
            </div>
            <div class="modal-footer" style="margin-top: 1.5rem;">
                <button type="button" class="btn btn-ghost" onclick="closeModal('editProjectModal')">Cancel</button>
                <button type="submit" class="btn btn-primary">Save Changes</button>
            </div>
        </form>
    </div>
</div>

<script>
    function openModal(id) { document.getElementById(id).style.display = 'flex'; }
    function closeModal(id) { document.getElementById(id).style.display = 'none'; }
    
    function editProject(id, name, desc, color, status) {
        document.getElementById('editProjectId').value = id;
        document.getElementById('editProjectName').value = name;
        document.getElementById('editProjectDesc').value = desc;
        document.getElementById('editProjectColor').value = color;
        document.getElementById('editProjectStatus').value = status;
        openModal('editProjectModal');
    }
</script>

<style>
    .project-card { transition: all 0.3s ease; }
    .project-card:hover { transform: translateY(-4px); box-shadow: 0 12px 24px rgba(0,0,0,0.06); }
    .badge-active { background: #ecfdf5; color: #059669; }
    .badge-onhold { background: #fffbeb; color: #d97706; }
    .badge-completed { background: #eff6ff; color: #2563eb; }
    .badge-cancelled { background: #fef2f2; color: #dc2626; }
</style>

<%- include('partials/foot') %>

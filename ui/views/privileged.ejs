<%- include('partials/head') %>

<div class="glass-card" style="margin-bottom: 2rem; padding: 1.5rem;">
    <div style="display: flex; justify-content: space-between; align-items: flex-start;">
        <div>
            <h2 style="margin:0; font-family: 'Outfit', sans-serif; display: flex; align-items: center; gap: 10px;">
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-primary"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
                Privileged Access Management
            </h2>
            <p style="margin: 0.5rem 0 0; color: var(--text-muted); font-size: 0.9rem;">
                Designate team members who can create AI skills and use administrative WhatsApp tools.
            </p>
        </div>
    </div>
</div>

<div class="glass-card" style="padding: 0; overflow: hidden;">
    <table class="table" style="margin:0;">
        <thead>
            <tr>
                <th>Contact</th>
                <th>Phone Number</th>
                <th>Current Role</th>
                <th style="text-align: center;">Administrative Access</th>
            </tr>
        </thead>
        <tbody>
            <% people.forEach(person => { %>
                <tr>
                    <td>
                        <div style="display: flex; align-items: center; gap: 0.75rem;">
                            <div class="avatar-sm"><%= person.Name.charAt(0) %></div>
                            <div style="font-weight: 600;"><%= person.Name %></div>
                        </div>
                    </td>
                    <td style="color: var(--text-muted); font-family: monospace;"><%= person.PhoneNumber %></td>
                    <td>
                        <span class="role-badge role-<%= person.Role %>"><%= person.Role %></span>
                    </td>
                    <td style="text-align: center;">
                        <input type="checkbox" class="admin-toggle" data-person-id="<%= person.Id %>" <%= person.IsAdmin ? 'checked' : '' %> onchange="toggleAdmin(this)">
                    </td>
                </tr>
            <% }) %>
        </tbody>
    </table>
</div>

<script>
async function toggleAdmin(checkbox) {
    const personId = checkbox.getAttribute('data-person-id');
    const isAdmin = checkbox.checked;
    
    checkbox.disabled = true;
    try {
        const response = await fetch('/privileged/toggle', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ personId, isAdmin })
        });
        const data = await response.json();
        if (!data.success) {
            alert('Error updating privileges: ' + data.error);
            checkbox.checked = !isAdmin;
        }
    } catch (err) {
        alert('Request failed');
        checkbox.checked = !isAdmin;
    } finally {
        checkbox.disabled = false;
    }
}
</script>

<style>
    .avatar-sm { width: 32px; height: 32px; background: var(--grad-brand-sm); color: white; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 0.8rem; font-weight: 700; }
    .admin-toggle { width: 20px; height: 20px; cursor: pointer; accent-color: var(--primary); }
</style>

<%- include('partials/foot') %>
